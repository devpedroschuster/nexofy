                    badge={
                      <Badge tone="warning">
                        {Math.ceil(
                          (new Date(a.data_fim_plano + 'T12:00:00') - agora) / (1000 * 60 * 60 * 24)
                        )}d
                      </Badge>
                    }
                  />
                ))}
              </div>
              <p className="text-xs text-warning font-medium mt-3">
