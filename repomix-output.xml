export default function ThemeToggle({ className }) {
  const { theme, setTheme } = useTheme();

  const opts = [
    { value: 'light', icon: Sun, label: 'Claro' },
    { value: 'system', icon: Monitor, label: 'Sistema' },
    { value: 'dark', icon: Moon, label: 'Escuro' },
