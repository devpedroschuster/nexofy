                    )}>
                      {isAniversario ? <Cake size={24} /> : <Package size={24} />}
                    </div>

                    {/* Conteúdo */}
                    <div className="min-w-0">
                      <h3 className="font-black text-foreground truncate">
                        {notif.aluno.nome_completo}
