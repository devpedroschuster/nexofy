                    const limiteAtingido = regraDestaAula && regraDestaAula.limite !== 999 && usosDestaAula >= regraDestaAula.limite;
                    return (
                      <div key={aula.id} className={`class-card anim-fade-up ${jaAgendado ? 'booked' : ''}`}>
