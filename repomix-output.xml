      return regrasPlano.some(r => r.modalidade === aulaArea);
    });
  }

  // FIX: verifica se o dia selecionado é feriado
  const feriadoDoDiaAtivo = feriadosDaSemana?.find(f => f.data === diaAtivo);

  return (
    <div id="page-dashboard">
