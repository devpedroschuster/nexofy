              </p>
            </SecaoAviso>
          )}

          {/* Planos vencendo em 7 dias */}
          {loadingVencendo ? (
            <Skeleton.Card />
          ) : alunosPlanosVencendo.length > 0 ? (
            <SecaoAviso
